        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "モデルが空の応答を返しました。質問を言い換えてお試しください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "모델이 빈 응답을 반환했어요. 질문을 다른 표현으로 다시 시도해 보세요."
