        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La ricerca è gestita da un server SearXNG privato. Nessuna ricerca viene salvata o tracciata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "検索はプライベートなSearXNGサーバーで行われます。検索内容が保存・追跡されることはありません。"
          }
        },
        "ko" : {
          "stringUnit" : {
